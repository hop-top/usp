# Default: text files normalize to LF, binary detection is automatic.
* text=auto eol=lf

# Explicit text formats — collapse cross-platform CRLF noise.
*.go          text eol=lf
*.md          text eol=lf
*.mdx         text eol=lf
*.yaml        text eol=lf
*.yml         text eol=lf
*.json        text eol=lf
*.toml        text eol=lf
*.proto       text eol=lf
*.ts          text eol=lf
*.tsx         text eol=lf
*.js          text eol=lf
*.jsx         text eol=lf
*.py          text eol=lf
*.sh          text eol=lf
*.bash        text eol=lf
*.bats        text eol=lf
Dockerfile    text eol=lf
*.Dockerfile  text eol=lf
Makefile      text eol=lf

# Explicit binary — never line-end-translate or diff.
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.ico         binary
*.pdf         binary
*.zip         binary
*.tar.gz      binary
*.tgz         binary
*.woff        binary
*.woff2       binary

# Lockfiles — generated, large, collapse from PR diffs.
go.sum                              linguist-generated=true

# E2E cassettes — generated by xrr record runs; collapse from PR diffs.
e2e/cassettes/**                    linguist-generated=true

# Vendored docs — exclude from language stats so they don't inflate
# the project's reported tech mix on GitHub.
docs/**            linguist-documentation=true
.tlc/**            linguist-vendored=true

# Test fixtures may carry binary or generated content; keep diffable
# but mark as generated so they don't dominate PR reviews.
**/testdata/**     linguist-generated=true
